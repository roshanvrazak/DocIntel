# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# --- AI / LLM ---
# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# --- Security ---
# API key required in X-API-Key header for all requests.
# Leave unset to disable auth in local dev.
API_KEY=your-secret-api-key-here

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# Default allows the local dev server only.
CORS_ORIGINS=http://localhost:3000

# --- Database ---
POSTGRES_USER=docintel
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=docintel
DATABASE_URL=postgresql://docintel:change-me-in-production@postgres:5432/docintel

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- File Upload ---
UPLOAD_DIR=/app/uploads
# Maximum upload size in megabytes (default: 50)
MAX_UPLOAD_SIZE_MB=50

# --- Chat ---
# Maximum allowed query length in characters (default: 2000)
MAX_QUERY_LENGTH=2000

# --- WebSocket ---
# Maximum concurrent WebSocket connections per client IP (default: 5)
MAX_WS_CONNECTIONS_PER_CLIENT=5
